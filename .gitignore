# ── System ───────────────────────────────────────────────────
.DS_Store

# ── Secrets (NEVER commit) ───────────────────────────────────
.env
.env.*
!.env.example
!.env.sample

# ── Claude Code / skills runtime ─────────────────────────────
CLAUDE.md
skills-lock.json
.claude/
skills/

# ── Power Engineer state (generated per-project) ────────────
.power-engineer/

# ── Internal docs (research, plans, prompts, scripts) ───────
# All internal working docs live in docs/internal/ — never committed
docs/internal/

# ── Local working directories ────────────────────────────────
plans/
docs/superpowers/prompts/
docs/superpowers/specs/
# Ignore ad-hoc scripts by default, but allow committed utility scripts
# to be explicitly re-included below.
scripts/*
!scripts/strip-cli-version-from-catalog.sh
!scripts/update-skill-count.sh
!scripts/run-behavioral-fixtures.sh
!scripts/hooks/
!scripts/hooks/*.sh

# ── Test artifacts (runtime output, not the test scripts) ────
test-projects/

# ── Planning / PRD files in root ─────────────────────────────
PRD.md

# ── Runtime / local tooling ──────────────────────────────────
.mcp.json
ruflo.config.json

